# Neon PostgreSQL — use the dev branch connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — generate with: openssl rand -hex 32
AUTH_SECRET="your-secret-here"

# GitHub OAuth — create an OAuth App at github.com/settings/developers
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# Resend — get your API key at resend.com
RESEND_API_KEY="re_your_api_key"

# Public URL of the app — used to build email links (password reset, verification)
APP_URL="http://localhost:3000"

# Set to "false" to skip email verification (useful when no custom Resend domain is configured)
REQUIRE_EMAIL_VERIFICATION="false"
